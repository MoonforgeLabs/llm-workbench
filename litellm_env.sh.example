#!/usr/bin/env bash
# LiteLLM 环境变量配置
# 复制为 litellm_env.sh 并填入你的实际 key:
#   cp litellm_env.sh.example litellm_env.sh

# PPIO (通过 CC Switch 代理，已有)
# CC Switch 自己管理 key，这里填个占位即可
export PPIO_API_KEY="ppio-via-cc-switch"

# Xiaomi MiMo (LiteLLM 原生支持)
# 注册: https://platform.xiaomimimo.com
export XIAOMI_MIMO_API_KEY="your-xiaomi-mimo-key"

# OpenRouter (一个 key 调 100+ 模型)
# 注册: https://openrouter.ai
export OPENROUTER_API_KEY="sk-or-your-openrouter-key"

# LiteLLM 管理密钥 (随意设置)
export LITELLM_MASTER_KEY="sk-litellm-local"
